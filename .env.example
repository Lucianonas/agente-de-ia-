# ================================================
# .env.example — Template de configuração
# ================================================
# COMO USAR:
# 1. Copie: copy .env.example .env
# 2. Preencha o .env com seus dados reais
# 3. NUNCA suba o .env pro GitHub
# ================================================


# -----------------------------------------------
# 🤖 IDENTIDADE DO JARVIS
# -----------------------------------------------

# Nome que o JARVIS vai usar pra se apresentar
JARVIS_NAME=JARVIS

# Versão atual do sistema
JARVIS_VERSION=1.0.0

# Idioma principal das respostas
JARVIS_LANGUAGE=pt-BR

# true = mostra mais info no terminal (útil pra debugar)
JARVIS_DEBUG=false


# -----------------------------------------------
# 🔑 CHAVES DE API — Preencha as que você tem
# -----------------------------------------------

# OpenAI (GPT-4): https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini

# Anthropic (Claude): https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-3-haiku-20240307

# Google Gemini (grátis): https://aistudio.google.com/
GOOGLE_API_KEY=
GEMINI_MODEL_DEFAULT=gemini-1.5-flash

# ElevenLabs (voz realista): https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=


# -----------------------------------------------
# 🦙 OLLAMA — IA local, sem internet, sem custo
# -----------------------------------------------

# Endereço do servidor Ollama rodando na sua máquina
OLLAMA_BASE_URL=http://localhost:11434

# Modelo padrão do Ollama (recomendado pra começar)
OLLAMA_MODEL_DEFAULT=llama3.2


# -----------------------------------------------
# 🌐 SERVIDOR
# -----------------------------------------------

# 0.0.0.0 = aceita conexões de qualquer IP
API_HOST=0.0.0.0

# Porta onde o servidor vai rodar
API_PORT=8000

# Chave secreta de segurança — troque por algo aleatório longo!
SECRET_KEY=troque-isso-por-algo-aleatorio-longo


# -----------------------------------------------
# 🗄️ BANCO DE DADOS
# -----------------------------------------------

# Banco principal SQLite (arquivo local)
DATABASE_URL=sqlite:///./database/jarvis.db

# Redis para dados temporários ultra-rápidos
REDIS_URL=redis://localhost:6379/0

# Pasta do ChromaDB (memória vetorial do JARVIS)
CHROMA_DB_PATH=./database/chroma_db


# -----------------------------------------------
# 🎙️ VOZ
# -----------------------------------------------

# Palavra que acorda o JARVIS para ouvir você
WAKE_WORD=jarvis

# Motor de voz: pyttsx3 (offline/grátis) ou elevenlabs (realista)
TTS_ENGINE=pyttsx3

# Motor de reconhecimento: whisper (preciso) ou google (internet)
STT_ENGINE=whisper

# Tamanho do Whisper: tiny=rápido | base | small | medium | large=preciso
WHISPER_MODEL_SIZE=base


# -----------------------------------------------
# 🔐 SEGURANÇA
# -----------------------------------------------

# true = isola comandos perigosos em sandbox
SANDBOX_ENABLED=true

# Máximo de tentativas de login antes de bloquear
MAX_LOGIN_ATTEMPTS=5